<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shahid products - AK Cell</title>

  <link rel="stylesheet" href="/css/bootstrap.css">
  <link rel="stylesheet" href="/css/custom.css">
  <link rel="stylesheet" href="/css/bootstrap-icons/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.css">
</head>
<body>

  <%- include('partials/header') %>

  <div class="container my-5">
    <h1 class="text-center mb-2">Shahid Products</h1>

  

    <!-- ✅ Quick admin sync button (only if admin user flag exists) -->
    <% 
      // Optional: adjust these flags to match your user object
      const isAdmin =
        user && (
          user.is_admin === 1 ||
          user.isAdmin === 1 ||
          user.role === 'admin' ||
          user.role === 'ADMIN'
        );
    %>

    <% if (isAdmin) { %>
      <div class="d-flex justify-content-center mb-3">
        <a href="/admin/shahid/sync-pending" class="btn btn-warning rounded-3">
          <i class="bi bi-arrow-repeat me-1"></i>
          Sync Pending Shahid Orders
        </a>
      </div>
    <% } %>

    <!-- Search -->
    <div class="container my-4">
      <div class="search-bar-container">
        <form id="searchForm" action="#" method="GET" role="search">
          <input type="search" id="searchInput" class="search-input" placeholder="Search for any service...">
          <button type="submit" class="search-btn">
            <i class="bi bi-search"></i>
          </button>
        </form>
      </div>
    </div>

    <!-- ✅ Shahid cards (API + DB pricing) -->
    <div class="row g-3" id="shahidCardsWrap">
      <% if (shahidCards && shahidCards.length > 0) { %>
        <% shahidCards.forEach(function(card) { %>

          <% const title = card.title || "Shahid"; %>
          <% const img = card.image || "/images/shahid.png"; %>

          <% const sharedPrice = (card.sell_price_shared != null && card.sell_price_shared !== "") ? Number(card.sell_price_shared) : null; %>
          <% const fullPrice   = (card.sell_price_full != null && card.sell_price_full !== "") ? Number(card.sell_price_full) : null; %>

          <div class="col-6 col-sm-4 col-md-3 shahid-card-col">
            <div class="product-card border-0 shadow-sm rounded-4 overflow-hidden text-center bg-white h-100 animate-zoom">

              <div class="product-image-wrapper mb-2">
                <img src="<%= img %>" alt="<%= title %>" class="img-fluid rounded-3">
              </div>

              <h6 class="fw-semibold text-dark mb-1"><%= title %></h6>

              <!-- Prices -->
              <div class="px-2 pb-2">
                <div class="d-flex justify-content-between small text-muted">
                  <span>Shared</span>
                  <span class="fw-semibold text-dark">
                    <% if (sharedPrice != null && !Number.isNaN(sharedPrice)) { %>
                      $<%= sharedPrice.toFixed(2) %>
                    <% } else { %>
                      -
                    <% } %>
                  </span>
                </div>

                <div class="d-flex justify-content-between small text-muted">
                  <span>Full</span>
                  <span class="fw-semibold text-dark">
                    <% if (fullPrice != null && !Number.isNaN(fullPrice)) { %>
                      $<%= fullPrice.toFixed(2) %>
                    <% } else { %>
                      -
                    <% } %>
                  </span>
                </div>

                <!-- Action buttons -->
                <div class="d-grid gap-2 mt-2">
                  <% if (!user) { %>
                    <a href="/login" class="btn btn-outline-primary btn-sm rounded-3">
                      Login to buy
                    </a>
                  <% } else { %>

                    <% if (sharedPrice != null && !Number.isNaN(sharedPrice)) { %>
                      <a href="/checkout/shahid/<%= encodeURIComponent(card.type) %>?full=0"
                         class="btn btn-primary btn-sm rounded-3">
                        Buy Shared
                      </a>
                    <% } else { %>
                      <button class="btn btn-secondary btn-sm rounded-3" disabled>
                        Shared Unavailable
                      </button>
                    <% } %>

                    <% if (fullPrice != null && !Number.isNaN(fullPrice)) { %>
                      <a href="/checkout/shahid/<%= encodeURIComponent(card.type) %>?full=1"
                         class="btn btn-outline-primary btn-sm rounded-3">
                        Buy Full
                      </a>
                    <% } else { %>
                      <button class="btn btn-secondary btn-sm rounded-3" disabled>
                        Full Unavailable
                      </button>
                    <% } %>

                  <% } %>
                </div>

              </div>
            </div>
          </div>

        <% }) %>
      <% } else { %>
        <div class="col-12 text-center">
          <p class="text-muted fs-5">No Shahid packages available right now.</p>
        </div>
      <% } %>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="/main.js"></script>

  <script>
    // ===== Search (filters shahid cards) =====
    document.addEventListener("DOMContentLoaded", function () {
      const searchInput = document.getElementById("searchInput");
      if (!searchInput) return;

      const searchForm = document.getElementById("searchForm");
      if (searchForm) searchForm.addEventListener("submit", e => e.preventDefault());

      searchInput.addEventListener("input", function () {
        const query = this.value.toLowerCase();
        const cols = document.querySelectorAll(".shahid-card-col");

        cols.forEach(col => {
          const title = col.querySelector("h6")?.textContent?.toLowerCase() || "";
          col.style.display = title.includes(query) ? "" : "none";
        });
      });
    });
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
