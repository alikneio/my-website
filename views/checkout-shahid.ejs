<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout - <%= product.name %></title>

  <link rel="stylesheet" href="/css/bootstrap.css">
  <link rel="stylesheet" href="/css/custom.css">
  <link rel="stylesheet" href="/css/bootstrap-icons/font/bootstrap-icons.css">
</head>
<body>

<%- include('partials/header') %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm rounded-4 border-0">
        <div class="card-body p-4">

          <h3 class="mb-3 text-center">Checkout</h3>

          <% if (error) { %>
            <div class="alert alert-danger rounded-4"><%= error %></div>
          <% } %>

          <!-- ✅ Pending notice (sync explanation) -->
          <div class="alert alert-info rounded-4 d-flex gap-2 align-items-start">
            <i class="bi bi-info-circle"></i>
            <div class="small">
              If your Shahid subscription returns <b>Pending</b>, it will be activated automatically when stock is available.
              You’ll be able to see the final credentials in <b>Order Details</b> after sync.
            </div>
          </div>

          <!-- Product Summary -->
          <div class="d-flex align-items-center mb-4">
            <img src="<%= product.image %>" style="width:90px; height:90px; object-fit:contain;" class="me-3 rounded-3 border">
            <div>
              <h5 class="mb-1"><%= product.name %></h5>
              <div class="text-muted small">
                <%= shahid.months %> month(s) • Shahid API
              </div>
            </div>
          </div>

          <hr>

          <!-- Hidden values -->
          <input type="hidden" id="shahidType" value="<%= product.type %>">
          <input type="hidden" id="idemKey" value="<%= idemKey %>">

          <!-- Account Type -->
          <div class="mb-3">
            <label class="form-label">Account Type</label>
            <select id="isFull" class="form-select">
              <option value="0" <%= shahid.isFull ? '' : 'selected' %>>Shared (Profile)</option>
              <option value="1" <%= shahid.isFull ? 'selected' : '' %>>Full Account</option>
            </select>
            <div class="form-text">Shared/Full affects the final price and the Shahid delivery.</div>
          </div>

          <!-- Customer Info -->
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">First Name</label>
              <input
                type="text"
                id="firstName"
                class="form-control"
                autocomplete="given-name"
                value="<%= (savedProfile && savedProfile.first_name) ? savedProfile.first_name : '' %>"
              >
            </div>
            <div class="col-md-6">
              <label class="form-label">Last Name</label>
              <input
                type="text"
                id="lastName"
                class="form-control"
                autocomplete="family-name"
                value="<%= (savedProfile && savedProfile.last_name) ? savedProfile.last_name : '' %>"
              >
            </div>
          </div>

          <div class="mt-3">
            <label class="form-label">Your phone number</label>
            <input
              type="text"
              id="phone"
              class="form-control"
              placeholder="96170000000"
              autocomplete="tel"
              value="<%= (savedProfile && savedProfile.phone) ? savedProfile.phone : '' %>"
            >
            <div class="form-text">Enter a phone number with at least 10 digits.</div>
          </div>

          <div class="mt-3">
            <label class="form-label">Country Code</label>
            <input
              type="text"
              id="countryCode"
              class="form-control"
              autocomplete="country"
              value="<%= (savedProfile && savedProfile.country_code) ? savedProfile.country_code : 'lb' %>"
            >
          </div>

          <!-- Remember Details -->
          <div class="form-check mt-3">
            <input class="form-check-input" type="checkbox" value="1" id="rememberDetails" checked>
            <label class="form-check-label" for="rememberDetails">
              Remember my details for next time
            </label>
          </div>

          <hr>

          <!-- Pricing -->
          <div class="d-flex justify-content-between mb-2">
            <span>Original Price</span>
            <span id="originalPrice">$<%= Number(product.original_price || 0).toFixed(2) %></span>
          </div>

          <% if (effectiveDiscount > 0) { %>
            <div class="d-flex justify-content-between mb-2 text-success">
              <span>Discount (<%= effectiveDiscount %>%)</span>
              <span id="discountLine">-</span>
            </div>
          <% } %>

          <div class="d-flex justify-content-between fw-bold fs-5">
            <span>Total</span>
            <span id="finalPrice">$<%= Number(product.price || 0).toFixed(2) %></span>
          </div>

          <hr>

          <div class="d-flex justify-content-between align-items-center">
            <div>
              <small class="text-muted">Your Balance</small><br>
              <strong>$<%= Number(user.balance || 0).toFixed(2) %></strong>
            </div>

            <button id="buyBtn" class="btn btn-primary btn-lg rounded-3">
              Confirm Purchase
            </button>
          </div>

          <div class="mt-3 alert alert-danger d-none rounded-4" id="errorBox"></div>
          <div class="mt-3 alert alert-success d-none rounded-4" id="successBox"></div>

        </div>
      </div>

    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  const sellShared = <%= Number(shahid.sellShared || 0) %>;
  const sellFull   = <%= Number(shahid.sellFull || 0) %>;
  const discountPercent = <%= Number(effectiveDiscount || 0) %>;

  function digitsCount(s){
    return String(s || '').replace(/\D/g, '').length;
  }

  function safeMoney(x){
    const n = Number(x);
    return Number.isFinite(n) ? n : 0;
  }

  function calculatePrice(isFull){
    const base = safeMoney(isFull ? sellFull : sellShared);
    let final = base;

    if (discountPercent > 0) {
      final = base - (base * discountPercent / 100);
    }

    document.getElementById('originalPrice').innerText = "$" + base.toFixed(2);
    document.getElementById('finalPrice').innerText = "$" + safeMoney(final).toFixed(2);
  }

  // initial
  calculatePrice(<%= shahid.isFull ? 'true' : 'false' %>);

  document.getElementById('isFull').addEventListener('change', function(){
    calculatePrice(this.value === "1");
  });

  function showError(msg){
    const box = document.getElementById("errorBox");
    const ok  = document.getElementById("successBox");
    if (ok) { ok.textContent = ""; ok.classList.add("d-none"); }
    box.textContent = msg || "Error";
    box.classList.remove("d-none");
  }

  function showSuccess(msg){
    const box = document.getElementById("successBox");
    const err = document.getElementById("errorBox");
    if (err) { err.textContent = ""; err.classList.add("d-none"); }
    box.textContent = msg || "Done";
    box.classList.remove("d-none");
  }

  function clearAll(){
    const box = document.getElementById("errorBox");
    const ok  = document.getElementById("successBox");
    box.textContent = "";
    box.classList.add("d-none");
    ok.textContent = "";
    ok.classList.add("d-none");
  }

  document.getElementById('buyBtn').addEventListener('click', async function(){
    clearAll();

    const phone = document.getElementById('phone').value.trim();
    const fn = document.getElementById('firstName').value.trim();
    const ln = document.getElementById('lastName').value.trim();

    // ✅ send as "0"/"1" (best compatibility)
    const isFullVal = document.getElementById('isFull').value; // "0" or "1"
    const cc = (document.getElementById('countryCode').value.trim() || "lb").toLowerCase();

    const remember = document.getElementById('rememberDetails').checked;

    const shahidType = document.getElementById('shahidType').value;
    const idemKey = document.getElementById('idemKey').value;

    if (!phone || digitsCount(phone) < 10) return showError("Invalid phone number (min 10 digits).");
    if (!fn || !ln) return showError("Enter first and last name.");

    // ✅ lock button
    this.disabled = true;
    const oldTxt = this.innerText;
    this.innerText = "Processing...";

    try {
      const resp = await fetch("/buy-shahid", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          shahidType,
          isFull: isFullVal, // "0"/"1"
          customerPhone: phone,
          customerFirstName: fn,
          customerLastName: ln,
          countryCode: cc,
          rememberDetails: remember ? 1 : 0,
          idempotency_key: idemKey
        })
      });

      const data = await resp.json().catch(() => null);

      if (!resp.ok || !data || !data.success) {
        throw new Error(data?.message || "Purchase failed");
      }

      // optional message before redirect
      showSuccess("✅ Order created. Redirecting to Order Details...");
      window.location = data.redirectUrl;

    } catch(e) {
      showError(e.message || "Error occurred");
      this.disabled = false;
      this.innerText = oldTxt;
    }
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
