<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Panel - Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link rel="stylesheet" href="/css/bootstrap.css">
  <link rel="stylesheet" href="/css/bootstrap-icons/font/bootstrap-icons.css">

  <style>
    :root{
      --bg:#f5f7fb;
      --card:#ffffff;
      --text:#111827;
      --muted:#6b7280;
      --line:rgba(15,23,42,.08);
      --shadow:0 12px 32px rgba(15,23,42,.07);
      --shadow-hover:0 18px 46px rgba(15,23,42,.12);
      --radius:18px;
      --primary:#0d6efd;
      --success:#198754;
      --danger:#dc3545;
      --warning:#f59f00;
      --purple:#6f42c1;
    }

    *{
      box-sizing:border-box;
    }

    body{
      background:
        radial-gradient(circle at top right, rgba(13,110,253,.08), transparent 28%),
        radial-gradient(circle at top left, rgba(111,66,193,.06), transparent 28%),
        var(--bg);
      color:var(--text);
    }

    .page-wrap{
      min-height:100vh;
    }

    .content-area{
      width:100%;
      padding:28px;
    }

    .soft-card{
      background:rgba(255,255,255,.92);
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      backdrop-filter: blur(10px);
    }

    .page-header{
      padding:20px;
      margin-bottom:18px;
    }

    .breadcrumb-mini{
      display:flex;
      align-items:center;
      gap:8px;
      color:var(--muted);
      font-size:.95rem;
      margin-bottom:4px;
    }

    .muted{
      color:var(--muted);
    }

    .form-help{
      font-size:.85rem;
      color:var(--muted);
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      border-radius:999px;
      padding:7px 12px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.7);
      font-size:.86rem;
      white-space:nowrap;
    }

    .stats-card{
      height:100%;
      padding:18px;
      transition:transform .16s ease, box-shadow .16s ease;
      overflow:hidden;
      position:relative;
    }

    .stats-card:hover{
      transform:translateY(-2px);
      box-shadow:var(--shadow-hover);
    }

    .stats-icon{
      width:46px;
      height:46px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:14px;
      font-size:1.25rem;
      background:rgba(13,110,253,.10);
      color:var(--primary);
    }

    .stats-icon.success{
      background:rgba(25,135,84,.12);
      color:var(--success);
    }

    .stats-icon.purple{
      background:rgba(111,66,193,.12);
      color:var(--purple);
    }

    .balance-shell{
      overflow:hidden;
    }

    .balance-header{
      padding:18px 20px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(135deg, rgba(13,110,253,.05), rgba(25,135,84,.04));
    }

    .section-title{
      display:flex;
      align-items:center;
      gap:10px;
      margin:0;
      font-weight:800;
    }

    .toolbox{
      background:#fff;
      border:1px solid var(--line);
      border-radius:16px;
      padding:14px;
    }

    .user-card{
      border:1px solid var(--line);
      border-radius:16px;
      padding:14px;
      background:linear-gradient(135deg, rgba(13,110,253,.05), rgba(255,255,255,.9));
      min-height:100%;
    }

    .avatar{
      width:44px;
      height:44px;
      border-radius:14px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      background:rgba(13,110,253,.11);
      color:var(--primary);
      font-weight:800;
      flex:0 0 auto;
    }

    .quick-btn{
      border:1px solid var(--line);
      background:#fff;
      border-radius:999px;
      padding:7px 12px;
      font-weight:650;
      transition:.15s ease;
    }

    .quick-btn:hover{
      transform:translateY(-1px);
      border-color:rgba(13,110,253,.35);
      color:var(--primary);
      background:rgba(13,110,253,.04);
    }

    .preview-box{
      border-radius:16px;
      border:1px dashed rgba(13,110,253,.25);
      background:rgba(13,110,253,.035);
      padding:14px;
    }

    .preview-number{
      font-size:1.18rem;
      font-weight:800;
    }

    .delta-badge{
      display:inline-flex;
      align-items:center;
      gap:6px;
      border-radius:999px;
      padding:6px 11px;
      font-weight:700;
      font-size:.88rem;
    }

    .delta-add{
      background:rgba(25,135,84,.10);
      color:var(--success);
    }

    .delta-deduct{
      background:rgba(220,53,69,.10);
      color:var(--danger);
    }

    .danger-soft{
      border-color:rgba(220,53,69,.28)!important;
      background:rgba(220,53,69,.045)!important;
    }

    .action-btn{
      min-height:46px;
      border-radius:14px;
      font-weight:750;
    }

    .confirm-overlay{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      background:rgba(15,23,42,.45);
      z-index:9999;
      padding:18px;
    }

    .confirm-box{
      width:min(520px, 100%);
      background:#fff;
      border-radius:20px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
    }

    .confirm-head{
      padding:18px 20px;
      border-bottom:1px solid var(--line);
    }

    .confirm-body{
      padding:18px 20px;
    }

    .confirm-actions{
      padding:14px 20px 20px;
      display:flex;
      justify-content:flex-end;
      gap:10px;
      flex-wrap:wrap;
    }

    @media (max-width: 992px){
      .content-area{
        padding:18px;
      }
    }

    @media (max-width: 576px){
      .content-area{
        padding:12px;
      }
    }
  </style>
</head>

<body>

<div class="d-flex page-wrap">

  <%- include('partials/admin-sidebar') %>

  <main class="content-area">

    <!-- HEADER -->
    <section class="soft-card page-header">

      <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">

        <div>

          <div class="breadcrumb-mini">
            <i class="bi bi-speedometer2 text-primary"></i>
            <span>Admin</span>
            <span>/</span>
            <span class="fw-semibold text-dark">Dashboard</span>
          </div>

          <h2 class="mb-1 fw-bold">
            Dashboard
          </h2>

          <div class="muted">
            Quick overview and faster balance management.
          </div>

        </div>

        <div class="d-flex align-items-center gap-2 flex-wrap">

          <span class="pill">
            <i class="bi bi-clock"></i>
            <span id="nowText">—</span>
          </span>

          <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="bi bi-box-arrow-left me-1"></i>
            Main Site
          </a>

        </div>

      </div>

    </section>

    <!-- STATS -->
    <section class="row g-3 mb-3">

      <div class="col-12 col-md-4">

        <div class="soft-card stats-card">

          <div class="d-flex align-items-start justify-content-between gap-3">

            <div>

              <div class="d-flex align-items-center gap-2 mb-3">
                <span class="stats-icon purple">
                  <i class="bi bi-people"></i>
                </span>

                <div class="muted">
                  Total Users
                </div>
              </div>

              <div class="fs-2 fw-bold">
                <%= stats.userCount %>
              </div>

              <div class="form-help">
                Registered accounts
              </div>

            </div>

            <i class="bi bi-person-check text-muted fs-5"></i>

          </div>

        </div>

      </div>

      <div class="col-12 col-md-4">

        <div class="soft-card stats-card">

          <div class="d-flex align-items-start justify-content-between gap-3">

            <div>

              <div class="d-flex align-items-center gap-2 mb-3">

                <span class="stats-icon">
                  <i class="bi bi-bag-check"></i>
                </span>

                <div class="muted">
                  Total Orders
                </div>

              </div>

              <div class="fs-2 fw-bold">
                <%= stats.orderCount %>
              </div>

              <div class="form-help">
                All orders created
              </div>

            </div>

            <i class="bi bi-receipt text-muted fs-5"></i>

          </div>

        </div>

      </div>

      <div class="col-12 col-md-4">

        <div class="soft-card stats-card">

          <div class="d-flex align-items-start justify-content-between gap-3">

            <div>

              <div class="d-flex align-items-center gap-2 mb-3">

                <span class="stats-icon success">
                  <i class="bi bi-cash-coin"></i>
                </span>

                <div class="muted">
                  Total Revenue
                </div>

              </div>

              <div class="fs-2 fw-bold text-success">
                $<%= parseFloat(stats.totalRevenue || 0).toFixed(2) %>
              </div>

              <div class="form-help">
                Sum of accepted orders
              </div>

            </div>

            <i class="bi bi-graph-up-arrow text-muted fs-5"></i>

          </div>

        </div>

      </div>

    </section>

    <!-- BALANCE -->
    <section class="soft-card balance-shell">

      <div class="balance-header">

        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">

          <div>

            <h5 class="section-title">

              <span class="stats-icon">
                <i class="bi bi-wallet2"></i>
              </span>

              Manage User Balances

            </h5>

            <div class="form-help mt-2">
              Search user, choose operation, preview result, then confirm.
            </div>

          </div>

          <span id="opBadge" class="pill">

            <i class="bi bi-plus-circle text-success"></i>

            <span>
              Operation: Add
            </span>

          </span>

        </div>

      </div>

      <div class="card-body p-3 p-md-4">

        <form id="balanceForm"
              action="/admin/update-balance"
              method="POST"
              onsubmit="return openConfirmBox()">

          <div class="row g-3">

            <!-- LEFT -->
            <div class="col-12 col-xl-5">

              <div class="toolbox h-100">

                <label class="form-label fw-bold">
                  <i class="bi bi-search me-1 text-primary"></i>
                  Find User
                </label>

                <input
                  type="text"
                  id="userSearch"
                  class="form-control form-control-lg"
                  placeholder="Search user..."
                  oninput="filterUsers()"
                >

                <div class="form-help mt-1">
                  Search by username or balance.
                </div>

                <label class="form-label fw-bold mt-3">
                  Select User
                </label>

                <select
                  name="userId"
                  id="userId"
                  class="form-select form-select-lg"
                  onchange="updatePreview()"
                  required
                >

                  <% users.forEach(u => { %>

                    <option
                      value="<%= u.id %>"
                      data-username="<%= u.username %>"
                      data-balance="<%= parseFloat(u.balance || 0) %>"
                    >

                      <%= u.username %> — Balance:
                      $<%= parseFloat(u.balance || 0).toFixed(2) %>

                    </option>

                  <% }) %>

                </select>

                <div class="user-card mt-3">

                  <div class="d-flex align-items-center gap-3">

                    <div class="avatar" id="avatarText">
                      U
                    </div>

                    <div>

                      <div class="muted small">
                        Selected user
                      </div>

                      <div class="fw-bold fs-5" id="userNameView">
                        —
                      </div>

                    </div>

                  </div>

                  <div class="row g-2 mt-3">

                    <div class="col-6">

                      <div class="muted small">
                        Current Balance
                      </div>

                      <div class="preview-number" id="curBal">
                        $0.00
                      </div>

                    </div>

                    <div class="col-6">

                      <div class="muted small">
                        After Operation
                      </div>

                      <div class="preview-number" id="newBal">
                        $0.00
                      </div>

                    </div>

                  </div>

                </div>

              </div>

            </div>

            <!-- RIGHT -->
            <div class="col-12 col-xl-7">

              <div class="toolbox h-100">

                <div class="row g-3 align-items-end">

                  <div class="col-12 col-md-5">

                    <label class="form-label fw-bold">
                      Amount
                    </label>

                    <div class="input-group input-group-lg">

                      <span class="input-group-text">
                        $
                      </span>

                      <input
                        type="number"
                        name="amount"
                        id="amount"
                        class="form-control"
                        placeholder="e.g. 50"
                        step="0.01"
                        min="0.01"
                        required
                        oninput="updatePreview()"
                      >

                    </div>

                  </div>

                  <div class="col-12 col-md-4">

                    <label class="form-label fw-bold">
                      Operation
                    </label>

                    <select
                      name="operation"
                      id="operation"
                      class="form-select form-select-lg"
                      onchange="updatePreview()"
                    >

                      <option value="add">
                        ➕ Add Balance
                      </option>

                      <option value="deduct">
                        ➖ Deduct Balance
                      </option>

                    </select>

                  </div>

                  <div class="col-12 col-md-3">

                    <button type="submit"
                            id="applyBtn"
                            class="btn btn-primary w-100 action-btn">

                      <i class="bi bi-check2-circle me-1"></i>
                      Apply

                    </button>

                  </div>

                  <!-- QUICK BUTTONS -->
                  <div class="col-12">

                    <div class="d-flex flex-wrap gap-2">

                      <button type="button" class="quick-btn" onclick="setAmount(1)">
                        $1
                      </button>

                      <button type="button" class="quick-btn" onclick="setAmount(5)">
                        $5
                      </button>

                      <button type="button" class="quick-btn" onclick="setAmount(10)">
                        $10
                      </button>

                      <button type="button" class="quick-btn" onclick="setAmount(20)">
                        $20
                      </button>

                      <button type="button" class="quick-btn" onclick="setAmount(50)">
                        $50
                      </button>

                      <button type="button" class="quick-btn" onclick="clearAmount()">
                        Clear
                      </button>

                    </div>

                  </div>

                  <!-- PREVIEW -->
                  <div class="col-12">

                    <div id="previewBox" class="preview-box">

                      <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">

                        <div>

                          <div class="muted small mb-1">
                            Preview
                          </div>

                          <div>

                            <strong id="selUser">
                              —
                            </strong>

                            <span class="muted">
                              balance will change from
                            </span>

                            <strong id="curBalInline">
                              $0.00
                            </strong>

                            <span class="muted">
                              to
                            </span>

                            <strong id="newBalInline">
                              $0.00
                            </strong>

                          </div>

                        </div>

                        <span id="deltaBadge" class="delta-badge delta-add">

                          <i class="bi bi-plus-circle"></i>

                          <span>
                            $0.00
                          </span>

                        </span>

                      </div>

                      <div id="warningText"
                           class="alert alert-danger mt-3 mb-0 d-none">

                        <i class="bi bi-exclamation-triangle me-1"></i>

                        Deduction is bigger than current balance.

                      </div>

                    </div>

                  </div>

                </div>

              </div>

            </div>

          </div>

        </form>

      </div>

    </section>

  </main>

</div>

<!-- CONFIRM BOX -->
<div id="confirmOverlay" class="confirm-overlay">

  <div class="confirm-box">

    <div class="confirm-head">

      <h5 class="mb-0 fw-bold">

        <i class="bi bi-shield-exclamation text-primary me-1"></i>

        Confirm Balance Update

      </h5>

    </div>

    <div class="confirm-body">

      <div id="confirmSummary">
        —
      </div>

    </div>

    <div class="confirm-actions">

      <button type="button"
              class="btn btn-outline-secondary rounded-pill px-4"
              onclick="closeConfirmBox()">

        Cancel

      </button>

      <button type="button"
              class="btn btn-primary rounded-pill px-4"
              onclick="submitConfirmed()">

        Yes, Apply

      </button>

    </div>

  </div>

</div>

<script>

let allowSubmit = false;

function money(n){
  const x = Number(n || 0);
  return "$" + (Number.isFinite(x) ? x.toFixed(2) : "0.00");
}

function getSelectedData(){

  const userSel = document.getElementById('userId');

  const opt = userSel.options[userSel.selectedIndex];

  const username =
    opt?.dataset?.username || '—';

  const current =
    Number(opt?.dataset?.balance || 0);

  const amount =
    Number(document.getElementById('amount').value || 0);

  const op =
    document.getElementById('operation').value;

  const after =
    op === 'add'
      ? current + amount
      : current - amount;

  return {
    username,
    current,
    amount,
    op,
    after
  };
}

function updatePreview(){

  const d = getSelectedData();

  document.getElementById('userNameView').textContent =
    d.username;

  document.getElementById('avatarText').textContent =
    d.username.slice(0,1).toUpperCase();

  document.getElementById('curBal').textContent =
    money(d.current);

  document.getElementById('newBal').textContent =
    money(d.after);

  document.getElementById('curBalInline').textContent =
    money(d.current);

  document.getElementById('newBalInline').textContent =
    money(d.after);

  document.getElementById('selUser').textContent =
    d.username;

  const opBadge =
    document.getElementById('opBadge');

  const deltaBadge =
    document.getElementById('deltaBadge');

  const warningText =
    document.getElementById('warningText');

  const previewBox =
    document.getElementById('previewBox');

  if(d.op === 'add'){

    opBadge.innerHTML =
      '<i class="bi bi-plus-circle text-success"></i><span>Operation: Add</span>';

    deltaBadge.className =
      'delta-badge delta-add';

    deltaBadge.innerHTML =
      '<i class="bi bi-plus-circle"></i><span>+' + money(d.amount) + '</span>';

  } else {

    opBadge.innerHTML =
      '<i class="bi bi-dash-circle text-danger"></i><span>Operation: Deduct</span>';

    deltaBadge.className =
      'delta-badge delta-deduct';

    deltaBadge.innerHTML =
      '<i class="bi bi-dash-circle"></i><span>-' + money(d.amount) + '</span>';
  }

  const negative =
    d.op === 'deduct' && d.after < 0;

  warningText.classList.toggle('d-none', !negative);

  previewBox.classList.toggle('danger-soft', negative);
}

function setAmount(v){
  document.getElementById('amount').value =
    Number(v).toFixed(2);

  updatePreview();
}

function clearAmount(){
  document.getElementById('amount').value = '';
  updatePreview();
}

function filterUsers(){

  const q =
    document.getElementById('userSearch')
      .value
      .trim()
      .toLowerCase();

  const sel =
    document.getElementById('userId');

  Array.from(sel.options).forEach(opt => {

    const text =
      opt.textContent.toLowerCase();

    opt.hidden =
      !text.includes(q);

  });

}

function openConfirmBox(){

  if(allowSubmit)
    return true;

  const d =
    getSelectedData();

  if(!d.amount || d.amount <= 0){

    alert("Please enter a valid amount.");

    return false;
  }

  document.getElementById('confirmSummary').innerHTML = `

    <div class="mb-2">

      User:
      <strong>${d.username}</strong>

    </div>

    <div class="mb-2">

      Operation:
      <strong>${d.op.toUpperCase()}</strong>

    </div>

    <div class="mb-2">

      Amount:
      <strong>${money(d.amount)}</strong>

    </div>

    <div>

      Balance:
      <strong>${money(d.current)}</strong>
      →
      <strong>${money(d.after)}</strong>

    </div>

  `;

  document.getElementById('confirmOverlay').style.display =
    'flex';

  return false;
}

function closeConfirmBox(){

  document.getElementById('confirmOverlay').style.display =
    'none';
}

function submitConfirmed(){

  allowSubmit = true;

  document.getElementById('balanceForm').submit();
}

function updateClock(){

  const el =
    document.getElementById('nowText');

  if(!el) return;

  el.textContent =
    new Date().toLocaleString();
}

window.addEventListener('DOMContentLoaded', () => {

  updatePreview();

  updateClock();

  setInterval(updateClock, 1000);
});

</script>

</body>
</html>