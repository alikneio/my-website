<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Tools - AK Cell</title>

    <link rel="stylesheet" href="/css/bootstrap.css">
    <link rel="stylesheet" href="/css/custom.css">
    <link rel="stylesheet" href="/css/bootstrap-icons/font/bootstrap-icons.css">

    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
</head>

<body>

<%- include('partials/header') %>

<div class="hero-section">
    <h1 class="display-4">AI Tools</h1>
    <p class="lead col-lg-8 mx-auto">
        All available AI tools and services in one place.
    </p>
</div>

<div class="container my-5">
    <div class="search-bar-container">
        <form id="searchForm">
            <input
                type="search"
                id="searchInput"
                class="search-input"
                placeholder="Search for any AI tool..."
            >
            <button type="submit" class="search-btn">
                <i class="bi bi-search"></i>
            </button>
        </form>
    </div>
</div>

<div class="container my-5 py-5">

    <h2 class="text-center section-title">
        Select an AI Tool
    </h2>

    <div class="row row-cols-2 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

        <div class="col">
            <a href="/chatgpt-section" class="category-card service-card">
                <img src="/images/chatgpt.png" class="card-img" alt="ChatGPT">
                <div class="card-body">ChatGPT</div>
            </a>
        </div>

        <div class="col">
            <a href="/claude" class="category-card service-card">
                <img src="/images/Claude.png" class="card-img" alt="Claude">
                <div class="card-body">Claude</div>
            </a>
        </div>

        <div class="col">
            <a href="/gemini" class="category-card service-card">
                <img src="/images/gemini.png" class="card-img" alt="Gemini">
                <div class="card-body">Gemini Pro</div>
            </a>
        </div>

        <div class="col">
            <a href="/perplexity" class="category-card service-card">
                <img src="/images/perplexity.png" class="card-img" alt="Perplexity">
                <div class="card-body">Perplexity AI</div>
            </a>
        </div>

        <div class="col">
            <a href="/openart" class="category-card service-card">
                <img src="/images/openart.png" class="card-img" alt="OpenArt">
                <div class="card-body">OpenArt AI</div>
            </a>
        </div>

        <div class="col">
            <a href="/gamma" class="category-card service-card">
                <img src="/images/gamma.png" class="card-img" alt="Gamma">
                <div class="card-body">Gamma AI</div>
            </a>
        </div>

        <div class="col">
            <a href="/hailuo" class="category-card service-card">
                <img src="/images/hailuo.png" class="card-img" alt="Hailuo">
                <div class="card-body">Hailuo AI</div>
            </a>
        </div>

        <div class="col">
            <a href="/lovable" class="category-card service-card">
                <img src="/images/lovable.png" class="card-img" alt="Lovable">
                <div class="card-body">Lovable AI</div>
            </a>
        </div>

        <div class="col">
            <a href="/grammarly" class="category-card service-card">
                <img src="/images/grammarly.png" class="card-img" alt="Grammarly">
                <div class="card-body">Grammarly</div>
            </a>
        </div>

        <div class="col">
            <a href="/canva-section" class="category-card service-card">
                <img src="/images/webp/canvalogo.webp" class="card-img" alt="Canva">
                <div class="card-body">Canva</div>
            </a>
        </div>

        <div class="col">
            <a href="/autodesk" class="category-card service-card">
                <img src="/images/autodesk.png" class="card-img" alt="Autodesk">
                <div class="card-body">Autodesk</div>
            </a>
        </div>

    </div>

</div>

<%- include('partials/footer') %>

<script>
document.addEventListener("DOMContentLoaded", () => {

    const input = document.getElementById("searchInput");

    input.addEventListener("input", function(){

        const value = this.value.toLowerCase();

        document.querySelectorAll(".category-card").forEach(card=>{

            const wrapper = card.closest(".col");
            const title = card.innerText.toLowerCase();

            wrapper.style.display =
                title.includes(value) ? "" : "none";

        });

    });

});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/main.js"></script>

</body>
</html>