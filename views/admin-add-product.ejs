<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add New Product - AK Cell</title>

  <link rel="stylesheet" href="/css/bootstrap.css">
  <link rel="stylesheet" href="/css/custom.css">
  <link rel="stylesheet" href="/css/bootstrap-icons/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.css"/>

  <style>
    .soft-card {
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 16px;
      background: #fff;
    }

    .section-title {
      font-weight: 800;
      margin-bottom: 10px;
    }

    .option-row {
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 14px;
      padding: 14px;
      background: #fafbfc;
      margin-bottom: 12px;
    }

    .option-row .remove-option-btn {
      min-width: 44px;
    }

    .d-none-force {
      display: none !important;
    }
  </style>
</head>

<body class="bg-light">
  <div class="d-flex">
    <%- include('partials/admin-sidebar') %>

    <div class="container-fluid p-4 p-lg-5">
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h1 class="mb-0">Add New Product</h1>
        <a href="/admin/products" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left"></i> Back
        </a>
      </div>

      <div class="card shadow-sm" style="border-radius: 16px;">
        <div class="card-body">
          <form action="/admin/products" method="POST" autocomplete="off" id="addProductForm">
            <div class="row g-3">

              <div class="col-12">
                <label class="form-label fw-semibold">Product Name</label>
                <input type="text" class="form-control" name="name" required>
              </div>

              <!-- Delivery Mode -->
              <div class="col-12 col-md-6">
                <label class="form-label fw-semibold">
                  <i class="bi bi-truck me-1"></i> Delivery Mode
                </label>
                <select class="form-select" name="delivery_mode" id="deliveryMode">
                  <option value="manual" selected>Manual (Admin processes order)</option>
                  <option value="stock">Stock (Auto delivery)</option>
                </select>

                <div class="form-text">
                  Stock = إذا في مخزون بيتسلم تلقائي، وإذا ما في → الطلب بيضل Pending / Waiting وينشاف من الأدمن.
                </div>

                <div id="stockHint" class="alert alert-info mt-2 mb-0 d-none" style="border-radius: 14px;">
                  <div class="d-flex gap-2">
                    <i class="bi bi-lightning-charge-fill"></i>
                    <div class="small">
                      بعد إنشاء المنتج، بتقدر تضيف الحسابات من صفحة:
                      <b>Manage Stock</b>.
                    </div>
                  </div>
                </div>
              </div>

              <!-- Pricing Mode -->
              <div class="col-12 col-md-6">
                <label class="form-label fw-semibold">
                  <i class="bi bi-cash-stack me-1"></i> Pricing Mode
                </label>
                <select class="form-select" name="pricing_mode" id="pricingMode">
                  <option value="fixed" selected>Fixed Price</option>
                  <option value="options">Options / Variants</option>
                </select>

                <div class="form-text">
                  Fixed = سعر واحد للمنتج. Options = الزبون يختار من عدة خيارات مثل 1$ / 2$ / 3$.
                </div>
              </div>

              <!-- Fixed Price -->
              <div class="col-12 col-md-6" id="fixedPriceWrap">
                <label class="form-label fw-semibold">Price</label>
                <input type="number" step="0.01" min="0" class="form-control" name="price" id="fixedPriceInput" required>
              </div>

              <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Main Category</label>
                <input type="text" class="form-control" name="main_category" placeholder="e.g., Accounts, Games" required>
              </div>

              <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Sub Category</label>
                <input type="text" class="form-control" name="sub_category" placeholder="e.g., Netflix, Free Fire" required>
              </div>

              <div class="col-12 col-md-4 d-flex align-items-end">
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="is_out_of_stock" name="is_out_of_stock" value="1">
                  <label class="form-check-label" for="is_out_of_stock">
                    Out of Stock
                  </label>
                  <div class="form-text">
                    (Optional) للـ Manual products. للـ Stock products الأفضل تتحكم بالمخزون من Stock Manager.
                  </div>
                </div>
              </div>

              <div class="col-12 col-md-6">
                <label class="form-label fw-semibold">Product Image Path</label>
                <input type="text" class="form-control" name="image" placeholder="/images/webp/product.webp">
                <div class="form-text">يفضّل تحط مسار كامل صحيح.</div>
              </div>

              <div class="col-12 col-md-6">
                <label class="form-label fw-semibold">Sub-Category Image Path</label>
                <input type="text" class="form-control" name="sub_category_image" placeholder="/images/webp/cat_netflix.webp">
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold">Description</label>
                <textarea class="form-control" name="description" rows="3"
                  placeholder="Product description shown in checkout details..."></textarea>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold">Product Notes (Optional)</label>
                <textarea class="form-control" name="notes" rows="3"
                  placeholder="Enter any notes or instructions for the user..."></textarea>
              </div>

              <div class="col-12 col-md-6">
                <label class="form-label fw-semibold">Field Label (مثلاً: Username, Email)</label>
                <input type="text" class="form-control" name="player_id_label" placeholder="Player ID">
              </div>

              <div class="col-12 col-md-6 d-flex align-items-end">
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="requires_player_id" name="requires_player_id" value="1">
                  <label class="form-check-label" for="requires_player_id">Requires Player ID?</label>
                </div>
              </div>

            </div>

            <!-- Options Section -->
            <div id="optionsSection" class="mt-4 d-none">
              <div class="soft-card p-3 p-md-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                  <div>
                    <h5 class="section-title mb-1">
                      <i class="bi bi-list-check me-1"></i> Product Options
                    </h5>
                    <div class="text-muted small">
                      أضف الخيارات اللي بدك المستخدم يختار بينها في صفحة الـ checkout.
                    </div>
                  </div>

                  <button type="button" class="btn btn-outline-primary" id="addOptionBtn">
                    <i class="bi bi-plus-circle me-1"></i> Add Option
                  </button>
                </div>

                <div id="optionsContainer"></div>

                <div class="alert alert-secondary mb-0 mt-2" style="border-radius: 14px;">
                  <div class="small">
                    <b>مثال:</b><br>
                    Label = 1 Dollar<br>
                    Value = 1<br>
                    Price = 100
                  </div>
                </div>
              </div>
            </div>

            <hr class="my-4">

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Add Product
              </button>
              <a href="/admin/products" class="btn btn-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>

      <%- include('partials/footer') %>
    </div>
  </div>

  <template id="optionRowTemplate">
    <div class="option-row">
      <div class="row g-3 align-items-end">
        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold">Option Label</label>
          <input type="text" class="form-control option-label-input" placeholder="e.g. 1 Dollar">
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label fw-semibold">Value</label>
          <input type="text" class="form-control option-value-input" placeholder="e.g. 1">
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label fw-semibold">Price</label>
          <input type="number" step="0.01" min="0" class="form-control option-price-input" placeholder="100">
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label fw-semibold">Sort</label>
          <input type="number" step="1" min="0" class="form-control option-sort-input" placeholder="0">
        </div>

        <div class="col-12 col-md-2">
          <div class="form-check mb-2">
            <input type="checkbox" class="form-check-input option-active-input" checked>
            <label class="form-check-label">Active</label>
          </div>

          <button type="button" class="btn btn-outline-danger w-100 remove-option-btn">
            <i class="bi bi-trash"></i>
          </button>
        </div>
      </div>
    </div>
  </template>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/main.js"></script>

  <script>
    const deliveryMode = document.getElementById('deliveryMode');
    const stockHint = document.getElementById('stockHint');

    const pricingMode = document.getElementById('pricingMode');
    const fixedPriceWrap = document.getElementById('fixedPriceWrap');
    const fixedPriceInput = document.getElementById('fixedPriceInput');
    const optionsSection = document.getElementById('optionsSection');
    const optionsContainer = document.getElementById('optionsContainer');
    const addOptionBtn = document.getElementById('addOptionBtn');
    const optionRowTemplate = document.getElementById('optionRowTemplate');
    const form = document.getElementById('addProductForm');

    function toggleHint() {
      if (!deliveryMode || !stockHint) return;
      const v = (deliveryMode.value || '').toLowerCase();
      if (v === 'stock') stockHint.classList.remove('d-none');
      else stockHint.classList.add('d-none');
    }

    function buildHiddenInput(name, value) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = name;
      input.value = value;
      input.className = 'generated-option-hidden';
      return input;
    }

    function refreshPricingMode() {
      const mode = (pricingMode?.value || 'fixed').toLowerCase();
      const isOptions = mode === 'options';

      fixedPriceWrap.classList.toggle('d-none', isOptions);
      optionsSection.classList.toggle('d-none', !isOptions);

      fixedPriceInput.required = !isOptions;

      if (isOptions && optionsContainer.children.length === 0) {
        addOptionRow();
      }
    }

    function addOptionRow(data = {}) {
      const fragment = optionRowTemplate.content.cloneNode(true);
      const row = fragment.querySelector('.option-row');

      const labelInput = row.querySelector('.option-label-input');
      const valueInput = row.querySelector('.option-value-input');
      const priceInput = row.querySelector('.option-price-input');
      const sortInput = row.querySelector('.option-sort-input');
      const activeInput = row.querySelector('.option-active-input');
      const removeBtn = row.querySelector('.remove-option-btn');

      labelInput.value = data.option_label || '';
      valueInput.value = data.option_value || '';
      priceInput.value = data.price || '';
      sortInput.value = data.sort_order || optionsContainer.children.length;
      activeInput.checked = typeof data.is_active === 'undefined' ? true : !!data.is_active;

      removeBtn.addEventListener('click', () => {
        row.remove();
      });

      optionsContainer.appendChild(row);
    }

    function rebuildOptionHiddenInputs() {
      form.querySelectorAll('.generated-option-hidden').forEach(el => el.remove());

      const mode = (pricingMode?.value || 'fixed').toLowerCase();
      if (mode !== 'options') return;

      const rows = optionsContainer.querySelectorAll('.option-row');

      rows.forEach((row, index) => {
        const label = row.querySelector('.option-label-input')?.value?.trim() || '';
        const value = row.querySelector('.option-value-input')?.value?.trim() || '';
        const price = row.querySelector('.option-price-input')?.value?.trim() || '';
        const sort = row.querySelector('.option-sort-input')?.value?.trim() || '0';
        const active = row.querySelector('.option-active-input')?.checked ? '1' : '0';

        form.appendChild(buildHiddenInput(`options[${index}][option_label]`, label));
        form.appendChild(buildHiddenInput(`options[${index}][option_value]`, value));
        form.appendChild(buildHiddenInput(`options[${index}][price]`, price));
        form.appendChild(buildHiddenInput(`options[${index}][sort_order]`, sort));
        form.appendChild(buildHiddenInput(`options[${index}][is_active]`, active));
      });
    }

    function validateOptionsMode() {
      const mode = (pricingMode?.value || 'fixed').toLowerCase();
      if (mode !== 'options') return true;

      const rows = optionsContainer.querySelectorAll('.option-row');
      if (!rows.length) {
        alert('Please add at least one option.');
        return false;
      }

      for (const row of rows) {
        const label = row.querySelector('.option-label-input')?.value?.trim() || '';
        const price = row.querySelector('.option-price-input')?.value?.trim() || '';

        if (!label) {
          alert('Each option must have a label.');
          return false;
        }

        if (price === '' || Number(price) < 0) {
          alert('Each option must have a valid price.');
          return false;
        }
      }

      return true;
    }

    toggleHint();
    refreshPricingMode();

    deliveryMode?.addEventListener('change', toggleHint);
    pricingMode?.addEventListener('change', refreshPricingMode);

    addOptionBtn?.addEventListener('click', () => addOptionRow());

    form?.addEventListener('submit', (e) => {
      if (!validateOptionsMode()) {
        e.preventDefault();
        return;
      }

      rebuildOptionHiddenInputs();
    });
  </script>
</body>
</html>