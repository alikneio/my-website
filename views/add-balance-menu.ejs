<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Add Balance - Whish | AK Cell</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link rel="stylesheet" href="/css/bootstrap.css">
  <link rel="stylesheet" href="/css/custom.css">
  <link rel="stylesheet" href="/css/bootstrap-icons/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --ak-blue: #0d6efd;
      --ak-green: #22c55e;
      --ak-dark: #0f172a;
      --ak-muted: #64748b;
      --ak-border: rgba(15, 23, 42, .09);
    }

    * { box-sizing: border-box; }

    body {
      font-family: 'Cairo', system-ui, sans-serif;
      min-height: 100vh;
      margin: 0;
      background:
        radial-gradient(circle at 10% 10%, rgba(13,110,253,.18), transparent 32%),
        radial-gradient(circle at 90% 90%, rgba(34,197,94,.18), transparent 34%),
        linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
      color: var(--ak-dark);
    }

    .page-wrap {
      min-height: 100vh;
      padding: 28px 14px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .balance-shell {
      width: 100%;
      max-width: 920px;
      background: rgba(255,255,255,.94);
      border: 1px solid rgba(255,255,255,.75);
      border-radius: 30px;
      box-shadow: 0 24px 70px rgba(15,23,42,.16);
      overflow: hidden;
    }

    .hero {
      padding: 30px;
      background:
        linear-gradient(135deg, rgba(13,110,253,.12), rgba(34,197,94,.10)),
        #fff;
      border-bottom: 1px solid var(--ak-border);
    }

    .hero-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      flex-wrap: wrap;
    }

    .brand-block {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .brand-icon {
      width: 62px;
      height: 62px;
      border-radius: 22px;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 1.9rem;
      background: linear-gradient(135deg, var(--ak-blue), var(--ak-green));
      box-shadow: 0 14px 28px rgba(13,110,253,.22);
    }

    .hero h1 {
      margin: 0;
      font-size: clamp(1.45rem, 3vw, 2rem);
      font-weight: 800;
    }

    .hero p {
      margin: 4px 0 0;
      color: var(--ak-muted);
      font-size: .95rem;
    }

    .security-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 13px;
      border-radius: 999px;
      background: #ecfdf5;
      color: #047857;
      border: 1px solid rgba(4,120,87,.14);
      font-weight: 700;
      font-size: .85rem;
      white-space: nowrap;
    }

    .content {
      padding: 30px;
      display: grid;
      grid-template-columns: 1.5fr .9fr;
      gap: 22px;
      align-items: start;
    }

    .currency-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .currency-card {
      position: relative;
      min-height: 190px;
      padding: 20px;
      border-radius: 24px;
      text-decoration: none;
      color: inherit;
      border: 1px solid var(--ak-border);
      background: #fff;
      box-shadow: 0 12px 30px rgba(15,23,42,.07);
      transition: .18s ease;
      overflow: hidden;
    }

    .currency-card::after {
      content: "";
      position: absolute;
      width: 130px;
      height: 130px;
      border-radius: 999px;
      right: -45px;
      bottom: -45px;
      opacity: .16;
    }

    .currency-card.usd::after { background: var(--ak-blue); }
    .currency-card.lbp::after { background: var(--ak-green); }

    .currency-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 45px rgba(15,23,42,.13);
      border-color: rgba(13,110,253,.25);
    }

    .currency-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 18px;
    }

    .currency-icon {
      width: 50px;
      height: 50px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 1.55rem;
    }

    .currency-icon.usd { background: linear-gradient(135deg, #2563eb, #0ea5e9); }
    .currency-icon.lbp { background: linear-gradient(135deg, #16a34a, #22c55e); }

    .tag {
      font-size: .72rem;
      font-weight: 800;
      border-radius: 999px;
      padding: 5px 10px;
      background: #f1f5f9;
      color: #334155;
    }

    .tag.recommended {
      background: #eff6ff;
      color: #1d4ed8;
    }

    .currency-card h3 {
      font-size: 1.2rem;
      font-weight: 800;
      margin: 0 0 6px;
    }

    .currency-card p {
      color: var(--ak-muted);
      font-size: .9rem;
      margin: 0 0 16px;
      line-height: 1.55;
    }

    .currency-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      color: #334155;
      font-weight: 700;
      font-size: .86rem;
      position: relative;
      z-index: 1;
    }

    .arrow {
      width: 34px;
      height: 34px;
      border-radius: 999px;
      background: #f8fafc;
      display: grid;
      place-items: center;
      color: var(--ak-blue);
    }

    .side-card {
      background: #f8fafc;
      border: 1px dashed rgba(100,116,139,.35);
      border-radius: 24px;
      padding: 20px;
    }

    .side-card h4 {
      font-size: 1rem;
      font-weight: 800;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .note-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .note-list li {
      display: flex;
      gap: 10px;
      color: #475569;
      font-size: .88rem;
      line-height: 1.5;
      margin-bottom: 12px;
    }

    .note-list i {
      color: var(--ak-blue);
      margin-top: 2px;
    }

    .support-note {
      margin-top: 14px;
      padding: 12px;
      border-radius: 16px;
      background: #fff;
      color: var(--ak-muted);
      font-size: .82rem;
      border: 1px solid var(--ak-border);
    }

    @media (max-width: 768px) {
      .page-wrap {
        align-items: flex-start;
        padding-top: 18px;
      }

      .balance-shell {
        border-radius: 24px;
      }

      .hero,
      .content {
        padding: 22px;
      }

      .content {
        grid-template-columns: 1fr;
      }

      .currency-grid {
        grid-template-columns: 1fr;
      }

      .currency-card {
        min-height: 170px;
      }

      .security-pill {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</head>

<body>
  <main class="page-wrap">
    <section class="balance-shell">

      <div class="hero">
        <div class="hero-inner">
          <div class="brand-block">
            <div class="brand-icon">
              <i class="bi bi-wallet2"></i>
            </div>

            <div>
              <h1>Add Balance with Whish</h1>
              <p>Choose the currency you want to use for your AK Cell wallet recharge.</p>
            </div>
          </div>

          <div class="security-pill">
            <i class="bi bi-shield-check"></i>
            Secure manual review
          </div>
        </div>
      </div>

      <div class="content">
        <div class="currency-grid">

          <a href="/add-balance/whish/usd" class="currency-card usd">
            <div class="currency-top">
              <div class="currency-icon usd">
                <i class="bi bi-currency-dollar"></i>
              </div>
              <span class="tag recommended">Recommended</span>
            </div>

            <h3>Recharge in USD</h3>
            <p>Best choice for stable pricing and services listed in dollars.</p>

            <div class="currency-footer">
              <span>Pay with USD</span>
              <span class="arrow"><i class="bi bi-arrow-right"></i></span>
            </div>
          </a>

          <a href="/add-balance/whish/lbp" class="currency-card lbp">
            <div class="currency-top">
              <div class="currency-icon lbp">
                <i class="bi bi-cash-coin"></i>
              </div>
              <span class="tag">Local</span>
            </div>

            <h3>Recharge in LBP</h3>
            <p>Use this option if you prefer paying in Lebanese pounds.</p>

            <div class="currency-footer">
              <span>Pay with LBP</span>
              <span class="arrow"><i class="bi bi-arrow-right"></i></span>
            </div>
          </a>

        </div>

        <aside class="side-card">
          <h4>
            <i class="bi bi-info-circle-fill text-primary"></i>
            Important Notes
          </h4>

          <ul class="note-list">
            <li>
              <i class="bi bi-check-circle-fill"></i>
              <span>After payment, upload a clear proof screenshot.</span>
            </li>
            <li>
              <i class="bi bi-check-circle-fill"></i>
              <span>Your request will be reviewed before the balance is added.</span>
            </li>
            <li>
              <i class="bi bi-check-circle-fill"></i>
              <span>Make sure the amount you submit matches the Whish transfer.</span>
            </li>
          </ul>

          <div class="support-note">
            <i class="bi bi-headset me-1"></i>
            Need help? Contact AK Cell support before submitting.
          </div>
        </aside>
      </div>

    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/main.js"></script>
</body>
</html>